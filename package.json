{
  "name": "ai-speedometer-monorepo",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/ai-speedometer",
    "packages/ai-speedometer-headless"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "build:core": "bun run --cwd packages/core build",
    "build:tui": "bun run --cwd packages/ai-speedometer build",
    "build:headless": "bun run --cwd packages/ai-speedometer-headless build",
    "test": "bun test packages/ai-speedometer/src/tests",
    "typecheck": "bun run --filter '*' typecheck",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  }
}
