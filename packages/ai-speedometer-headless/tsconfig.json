{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun-types"],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@ai-speedometer/core/*": ["../core/src/*"]
    }
  },
  "include": ["src/**/*"]
}
